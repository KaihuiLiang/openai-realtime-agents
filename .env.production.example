# Production environment example
# Copy to .env.production on the server.

# OpenAI
OPENAI_API_KEY=replace-with-production-key
NEXT_PUBLIC_REALTIME_MODEL=gpt-realtime-mini

# Backend API
BACKEND_PORT=8001
BACKEND_URL=http://127.0.0.1:8001
NEXT_PUBLIC_BACKEND_URL=https://your-domain.example

# Frontend
FRONTEND_PORT=3001
NEXT_PUBLIC_APP_URL=https://your-domain.example

# Node environment
NODE_ENV=production

# Production database (replace with your real DB URL)
DATABASE_URL=postgresql://user:password@db-host:5432/realtime_agents

# Docker user mapping (if needed)
UID=1000
GID=1000
