# Development environment example
# Copy to .env.development for local/dev runtime.

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
NEXT_PUBLIC_REALTIME_MODEL=gpt-realtime-mini

# Backend API
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Local database (if used by local backend process)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/realtime_agents

# Docker user mapping (used by docker-compose.dev.yml)
UID=1000
GID=1000
